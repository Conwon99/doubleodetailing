---
import '../styles/tailwind.css';
import { locations } from '../data/locations';

interface LocationSchemaProp {
  name: string;
  slug: string;
  addressLocality: string;
  latitude: string;
  longitude: string;
}

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  canonical?: string;
  noindex?: boolean;
  locationSchema?: LocationSchemaProp;
}

const {
  title = "Jimbos Cleaning - Professional Exterior Cleaning in Ayrshire & Glasgow",
  description = "Expert roof cleaning, render softwashing, driveway, gutter, PVC and window cleaning across Ayrshire and Glasgow. Professional exterior cleaning services for your home or business.",
  image = "https://jimboscleaning.com/logo.png",
  type = "website",
  canonical = Astro.url.pathname === '/' ? 'https://jimboscleaning.com/' : `https://jimboscleaning.com${Astro.url.pathname}`,
  noindex = false,
  locationSchema,
} = Astro.props;

const siteUrl = "https://jimboscleaning.com";
const fullImageUrl = image.startsWith('http') ? image : `${siteUrl}${image}`;

const defaultAreaServed = [
  ...locations.map((loc) => ({ "@type": "City", "name": loc.name })),
  { "@type": "State", "name": "Ayrshire" },
  { "@type": "City", "name": "Glasgow" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content="roof cleaning, exterior cleaning, roof steam cleaning, render softwashing, driveway cleaning, gutter cleaning, PVC cleaning, window cleaning, Ayrshire, Glasgow, moss removal, algae removal" />
    <meta name="author" content="Jimbos Cleaning" />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <meta name="language" content="English" />
    <meta name="revisit-after" content="7 days" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonical} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImageUrl} />
    <meta property="og:site_name" content="Jimbos Cleaning" />
    <meta property="og:locale" content="en_GB" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImageUrl} />
    
    <!-- Business Information -->
    <meta name="geo.region" content="GB-SCT" />
    <meta name="geo.placename" content="Ayrshire, Scotland" />
    <meta name="geo.position" content="55.4620;-4.6299" />
    <meta name="ICBM" content="55.4620, -4.6299" />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&family=Bungee&family=Courier+Prime:ital,wght@0,400;0,700;1,400;1,700&family=Luckiest+Guy&family=Manrope:wght@200..800&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
    
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-YMJS781CJF"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-YMJS781CJF');
    </script>
    
    <!-- JSON-LD Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": "https://jimboscleaning.com/#localbusiness",
      "name": "Jimbos Cleaning",
      "alternateName": "Jimbo's Exterior Cleaning",
      "description": "Expert roof cleaning and exterior cleaning services in Ayrshire and Glasgow. Roof steam cleaning, render softwashing, driveway, gutter, PVC and window cleaning.",
      "url": "https://jimboscleaning.com",
      "logo": "https://jimboscleaning.com/logo.png",
      "image": "https://jimboscleaning.com/logo.png",
      "telephone": "+447919270128",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "2 West Bowhouse Way",
        "addressLocality": "Irvine",
        "addressRegion": "Ayrshire",
        "addressCountry": "GB"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "55.4620",
        "longitude": "-4.6299"
      },
      "areaServed": defaultAreaServed,
      "serviceType": [
        "Roof Cleaning",
        "Roof Steam Cleaning",
        "Render Softwashing",
        "Driveway Cleaning",
        "Gutter Cleaning",
        "PVC Cleaning",
        "Window Cleaning",
        "Exterior Cleaning"
      ],
      "priceRange": "$$",
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "08:00",
        "closes": "18:00"
      },
      "sameAs": [
        "https://www.facebook.com/profile.php?id=100076596473868"
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5",
        "reviewCount": "23",
        "bestRating": "5",
        "worstRating": "1"
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": "https://jimboscleaning.com/#website",
      "name": "Jimbos Cleaning",
      "url": "https://jimboscleaning.com",
      "description": "Professional exterior cleaning in Ayrshire and Glasgow. Roof steam cleaning, render softwashing, driveway, gutter, PVC and window cleaning.",
      "publisher": { "@id": "https://jimboscleaning.com/#organization" },
      "inLanguage": "en-GB",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://jimboscleaning.com/contact?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    })} />
    
    {locationSchema && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": `Jimbos Cleaning – ${locationSchema.name}`,
        "description": "Professional exterior cleaning: roof steam cleaning, render softwashing, driveway, gutter, PVC and window cleaning.",
        "url": `${siteUrl}/${locationSchema.slug}`,
        "telephone": "+447919270128",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": locationSchema.addressLocality,
          "addressRegion": "Ayrshire",
          "addressCountry": "GB"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": locationSchema.latitude,
          "longitude": locationSchema.longitude
        },
        "areaServed": { "@type": "City", "name": locationSchema.addressLocality },
        "serviceType": ["Roof Cleaning", "Render Softwashing", "Driveway Cleaning", "Gutter Cleaning", "PVC Cleaning", "Window Cleaning", "Exterior Cleaning"],
        "priceRange": "$$",
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "5",
          "reviewCount": "23",
          "bestRating": "5",
          "worstRating": "1"
        }
      })} />
    )}
    
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": "https://jimboscleaning.com/#organization",
      "name": "Jimbos Cleaning",
      "url": "https://jimboscleaning.com",
      "logo": "https://jimboscleaning.com/logo.png",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+447919270128",
        "contactType": "Customer Service",
        "areaServed": "GB",
        "availableLanguage": "English"
      },
      "sameAs": [
        "https://www.facebook.com/profile.php?id=100076596473868"
      ]
    })} />
  </head>
  <body>
    <slot />
    <!-- Mobile message widget - bottom right, visible on small screens only -->
    <a
      href="/contact"
      class="fixed bottom-5 right-5 z-50 flex md:hidden items-center gap-2 bg-cta-dark text-white px-4 py-3 rounded-full shadow-lg hover:bg-cta focus:outline-none focus:ring-2 focus:ring-cta-dark focus:ring-offset-2"
      aria-label="Message us / Get a quote"
    >
      <svg class="w-6 h-6 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.864 9.864 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
      </svg>
      <span class="font-medium text-sm">Message</span>
    </a>
  </body>
</html>
