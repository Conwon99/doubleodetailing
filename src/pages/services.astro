---
import Layout from '../layouts/Layout.astro';
import { Navbar } from '../sections/Navbar';
import { ServicePageHero } from '../sections/ServicePageHero';
import { ServicePageServices } from '../sections/ServicePageServices';
import { QuoteSection } from '../sections/QuoteSection';
import { FooterSection } from '../sections/FooterSection';
---

<Layout 
  title="Our Services - Jimbos Cleaning | Roof, Render, Driveway & More"
  description="Roof steam cleaning, render softwashing, driveway, gutter, PVC and window cleaning across Ayrshire and Glasgow. Professional exterior cleaning for your property."
>
  <div class="min-h-screen bg-neutral-100 font-figtree text-black text-sm leading-5 antialiased">
    <Navbar client:load />
    <main class="pt-0">
      <ServicePageHero client:load />
      <ServicePageServices client:load />
      <QuoteSection client:load showTerms={false} />
      <FooterSection client:load />
    </main>
  </div>
</Layout>
