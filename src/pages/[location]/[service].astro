---
import Layout from "../../layouts/Layout.astro";
import { Navbar } from "../../sections/Navbar";
import { HeroStats } from "../../sections/Hero/components/HeroStats";
import { WhyChooseMachinePolishingSection } from "../../sections/CoreValuesSection/WhyChooseMachinePolishingSection";
import { WhyChooseCeramicCoatingsSection } from "../../sections/CoreValuesSection/WhyChooseCeramicCoatingsSection";
import { WhyChooseDeepCleanSection } from "../../sections/CoreValuesSection/WhyChooseDeepCleanSection";
import { WhyChooseMaintenanceSection } from "../../sections/CoreValuesSection/WhyChooseMaintenanceSection";
import { WhyChooseHeadlightRestorationSection } from "../../sections/CoreValuesSection/WhyChooseHeadlightRestorationSection";
import { WhyChooseSoftTopSection } from "../../sections/CoreValuesSection/WhyChooseSoftTopSection";
import { WhyChooseInteriorFabricCoatingSection } from "../../sections/CoreValuesSection/WhyChooseInteriorFabricCoatingSection";
import { WhyChooseEngineBaySection } from "../../sections/CoreValuesSection/WhyChooseEngineBaySection";
import { ProcessSectionMachinePolishing } from "../../sections/ProcessSection/ProcessSectionMachinePolishing";
import { ProcessSectionCeramicCoatings } from "../../sections/ProcessSection/ProcessSectionCeramicCoatings";
import { ProcessSectionDeepClean } from "../../sections/ProcessSection/ProcessSectionDeepClean";
import { ProcessSectionMaintenance } from "../../sections/ProcessSection/ProcessSectionMaintenance";
import { ProcessSectionHeadlightRestoration } from "../../sections/ProcessSection/ProcessSectionHeadlightRestoration";
import { ProcessSectionSoftTop } from "../../sections/ProcessSection/ProcessSectionSoftTop";
import { ProcessSectionInteriorFabricCoating } from "../../sections/ProcessSection/ProcessSectionInteriorFabricCoating";
import { ProcessSectionEngineBay } from "../../sections/ProcessSection/ProcessSectionEngineBay";
import { MachinePolishingFAQ } from "../../sections/FAQSection/MachinePolishingFAQ";
import { CeramicCoatingsFAQ } from "../../sections/FAQSection/CeramicCoatingsFAQ";
import { DeepCleanFAQ } from "../../sections/FAQSection/DeepCleanFAQ";
import { MaintenanceFAQ } from "../../sections/FAQSection/MaintenanceFAQ";
import { HeadlightRestorationFAQ } from "../../sections/FAQSection/HeadlightRestorationFAQ";
import { SoftTopFAQ } from "../../sections/FAQSection/SoftTopFAQ";
import { InteriorFabricCoatingFAQ } from "../../sections/FAQSection/InteriorFabricCoatingFAQ";
import { EngineBayFAQ } from "../../sections/FAQSection/EngineBayFAQ";
import { ServiceAreasSection } from "../../sections/ServiceAreasSection";
import ReviewsSection from "../../sections/ReviewsSection.astro";
import { QuoteSection } from "../../sections/QuoteSection";
import { FooterSection } from "../../sections/FooterSection";
import { Breadcrumbs } from "../../components/Breadcrumbs";
import { getLocationBySlug } from "../../data/locations";
import { getServiceBySlug } from "../../data/services";

export async function getStaticPaths() {
  const { locationSlugs } = await import("../../data/locations");
  const { serviceSlugs } = await import("../../data/services");
  const paths: { params: { location: string; service: string } }[] = [];
  for (const location of locationSlugs) {
    for (const service of serviceSlugs) {
      paths.push({ params: { location, service } });
    }
  }
  return paths;
}

const { location: locationSlug, service: serviceSlug } = Astro.params;
const location = getLocationBySlug(locationSlug ?? "");
const service = getServiceBySlug(serviceSlug ?? "");

if (!location || !service) {
  return Astro.redirect("/404");
}

const siteUrl = "https://doubleodetailing.co.uk";
const canonical = `${siteUrl}/${location.slug}/${service.slug}`;
const title = `${service.title} ${location.name} | Who's the Best ${service.title} Near Me? | Double O Detailing`;
const description = `${service.shortDescription} We come to you in ${location.name} and the surrounding areas. Book mobile ${service.title.toLowerCase()} with Double O Detailing.`;

const heroDescriptions: Record<string, string> = {
  "machine-polishing": `Swirl marks and dull paint are common after Scottish winters. We bring professional machine polishing to ${location.name}—restore your paintwork and protect it with a lasting finish, at your home or workplace.`,
  "ceramic-coatings": `Long-lasting ceramic coating protection for your vehicle. We come to you in ${location.name} and the surrounding areas—superior defence against UV, chemicals, and environmental damage with a hydrophobic, easy-to-maintain finish.`,
  "deep-cleans": `Comprehensive deep cleaning and valeting to keep your vehicle immaculate inside and out. We bring the same attention to every detail to ${location.name}—book a slot that suits you.`,
  "maintenance": `Regular maintenance keeps your vehicle in pristine condition. We provide ongoing care programmes in ${location.name} and nearby—protect your investment with our mobile maintenance packages.`,
  "headlight-restoration": `Cloudy or yellowed headlights are a common issue. We restore and protect headlights in ${location.name} and the surrounding areas—improved visibility and a like-new appearance at your doorstep.`,
  "soft-top-restoration": `Revive and protect convertible and soft tops with specialist cleaning and coating. We bring our mobile service to ${location.name}—lasting finish and protection for your roof.`,
  "interior-fabric-coating": `Protect upholstery, carpets, and mats with fabric coating. We come to you in ${location.name} and nearby—repels stains and moisture while keeping interiors looking fresh.`,
  "engine-bay-detailing": `Thorough cleaning and dressing of the engine bay. We provide safe, professional treatment in ${location.name} and the surrounding areas—showcase and protect under-bonnet areas at your home or workplace.`,
};
const heroDescription = heroDescriptions[service.slug] ?? `${service.shortDescription} We come to you in ${location.name} and the surrounding areas. Book a slot that suits you.`;

const packagesHref =
  service.slug === "machine-polishing"
    ? "/packages/machine-polishing"
    : service.slug === "deep-cleans"
      ? "/packages/deep-clean"
      : service.slug === "maintenance"
        ? "/packages/maintenance"
        : "/packages";
const packagesLabel =
  service.slug === "machine-polishing"
    ? "View Machine Polishing Packages"
    : service.slug === "deep-cleans"
      ? "View Deep Clean Packages"
      : service.slug === "maintenance"
        ? "View Maintenance Packages"
        : "View Our Packages";
---

<Layout title={title} description={description} canonical={canonical}>
  <div class="min-h-screen bg-neutral-100 font-figtree text-black text-sm leading-5 antialiased">
    <Navbar client:load />
    <main class="pt-0">
      <div class="relative mx-auto max-w-[1204px] px-5 pt-8 md:px-8">
        <Breadcrumbs
          client:load
          items={[
            { label: "Home", href: "/" },
            { label: "Locations", href: "/locations" },
            { label: location.name, href: `/${location.slug}` },
            { label: service.title },
          ]}
        />
      </div>

      <section class="relative text-white overflow-hidden min-h-screen">
        <div class="absolute inset-0">
          <div
            class="absolute inset-0 bg-cover bg-center bg-no-repeat"
            style={`background-image: url("${service.imageUrl}");`}
          />
        </div>
        <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/50 to-transparent" />
        <div class="relative mx-auto flex min-h-screen w-full max-w-[1204px] flex-col justify-end px-5 pb-8 pt-32 md:px-8 md:pb-12 md:pt-28 supports-[min-height:100dvh]:min-h-[100dvh]">
          <div class="items-start box-border gap-x-10 flex flex-col justify-between gap-y-10 md:items-end md:gap-x-[60px] md:flex-row md:gap-y-[60px] w-full">
            <div class="box-border basis-[0%] grow max-w-[650px] pt-24 md:pt-32">
              <div class="box-border gap-x-4 flex flex-col gap-y-4">
                <h1 class="text-[44px] font-bold box-border tracking-[-1.44px] leading-[52px] md:text-7xl md:leading-[80px] font-refrigerator uppercase">
                  <div>{service.title}</div>
                  <div class="text-gray-400">{location.name}</div>
                </h1>
                <p class="text-base leading-[26px] md:text-lg font-figtree">
                  {heroDescription}
                </p>
              </div>
              <div class="items-center box-border gap-x-5 flex flex-wrap gap-y-5 mt-6 md:gap-x-6 md:gap-y-6 md:mt-7">
                <a
                  href="/contact"
                  class="text-black items-center bg-cta box-border gap-x-5 flex max-w-full gap-y-5 text-center border pl-6 pr-1 py-1 rounded-[100px] border-solid border-transparent hover:bg-white hover:border-cta-dark"
                >
                  <span class="relative text-sm font-medium z-[2] md:text-base md:leading-6">BOOK NOW</span>
                  <span class="text-white items-center bg-[#8B6B3D] box-border flex h-12 justify-center w-12 overflow-hidden rounded-[50%]">
                    <img src="https://c.animaapp.com/mhnzg6knJo6lE7/assets/icon-4.svg" alt="" class="h-3.5 w-3.5" style="filter: brightness(0) saturate(100%) invert(78%) sepia(45%) saturate(500%) hue-rotate(330deg) brightness(110%) contrast(85%)" />
                  </span>
                </a>
                <a href={packagesHref} class="relative items-center box-border gap-x-2 flex max-w-full gap-y-2 overflow-hidden">
                  <span class="text-[15px] font-medium leading-6 md:text-base">
                    {packagesLabel}
                  </span>
                  <span class="relative h-6 w-6 overflow-hidden">
                    <img src="https://c.animaapp.com/mhnzg6knJo6lE7/assets/icon-5.svg" alt="" class="h-full w-full" />
                  </span>
                  <span class="absolute bg-white box-border h-px bottom-0 inset-x-0" />
                </a>
              </div>
            </div>
            <HeroStats client:load />
          </div>
        </div>
      </section>

      {service.slug === "machine-polishing" && (
        <>
          <WhyChooseMachinePolishingSection client:load />
          <ProcessSectionMachinePolishing client:load />
          <MachinePolishingFAQ client:load />
        </>
      )}
      {service.slug === "ceramic-coatings" && (
        <>
          <WhyChooseCeramicCoatingsSection client:load />
          <ProcessSectionCeramicCoatings client:load />
          <CeramicCoatingsFAQ client:load />
        </>
      )}
      {service.slug === "deep-cleans" && (
        <>
          <WhyChooseDeepCleanSection client:load />
          <ProcessSectionDeepClean client:load />
          <DeepCleanFAQ client:load />
        </>
      )}
      {service.slug === "maintenance" && (
        <>
          <WhyChooseMaintenanceSection client:load />
          <ProcessSectionMaintenance client:load />
          <MaintenanceFAQ client:load />
        </>
      )}
      {service.slug === "headlight-restoration" && (
        <>
          <WhyChooseHeadlightRestorationSection client:load />
          <ProcessSectionHeadlightRestoration client:load />
          <HeadlightRestorationFAQ client:load />
        </>
      )}
      {service.slug === "soft-top-restoration" && (
        <>
          <WhyChooseSoftTopSection client:load />
          <ProcessSectionSoftTop client:load />
          <SoftTopFAQ client:load />
        </>
      )}
      {service.slug === "interior-fabric-coating" && (
        <>
          <WhyChooseInteriorFabricCoatingSection client:load />
          <ProcessSectionInteriorFabricCoating client:load />
          <InteriorFabricCoatingFAQ client:load />
        </>
      )}
      {service.slug === "engine-bay-detailing" && (
        <>
          <WhyChooseEngineBaySection client:load />
          <ProcessSectionEngineBay client:load />
          <EngineBayFAQ client:load />
        </>
      )}

      <ServiceAreasSection client:load />
      <ReviewsSection title="Reviews" />
      <QuoteSection client:load showTerms={false} />
      <FooterSection client:load />
    </main>
  </div>
</Layout>
