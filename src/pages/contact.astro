---
import Layout from '../layouts/Layout.astro';
import { Navbar } from '../sections/Navbar';
import { QuoteSection } from '../sections/QuoteSection';
import { FooterSection } from '../sections/FooterSection';
---

<Layout 
  title="Contact Us - Double O Detailing | Get a Free Quote"
  description="Contact Double O Detailing for a free quote on car detailing services. Call 07768 243 728 or fill out our contact form. Serving Glasgow, Stirling, and Central Scotland."
  canonical="https://doubleodetailing.co.uk/contact"
>
  <div class="min-h-screen bg-neutral-100 font-figtree text-black text-sm leading-5 antialiased">
    <Navbar client:load />
    <main class="pt-0">
      <QuoteSection client:load showTerms={false} />
      <FooterSection client:load />
    </main>
  </div>
</Layout>
