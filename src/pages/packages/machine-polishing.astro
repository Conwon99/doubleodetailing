---
import Layout from '../../layouts/Layout.astro';
import { Navbar } from '../../sections/Navbar';
import { PackageCategorySection } from '../../sections/PackageCategorySection';
import { QuoteSection } from '../../sections/QuoteSection';
import { FooterSection } from '../../sections/FooterSection';
---

<Layout 
  title="Machine Polishing & Coatings - Double O Detailing | Glasgow"
  description="Machine polishing and ceramic coating packages: Casino Royale and Snow Time To Die. Single-stage machine polish, 1-year and 2-year ceramic coatings. Professional car detailing in Glasgow."
  canonical="https://doubleodetailing.co.uk/packages/machine-polishing"
>
  <div class="min-h-screen bg-neutral-100 font-figtree text-black text-sm leading-5 antialiased">
    <Navbar client:load />
    <main class="pt-0">
      <PackageCategorySection client:load categoryId="machine-polishing" />
      <QuoteSection client:load showTerms={false} />
      <FooterSection client:load />
    </main>
  </div>
</Layout>
