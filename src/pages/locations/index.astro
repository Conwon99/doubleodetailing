---
import Layout from "../../layouts/Layout.astro";
import { Navbar } from "../../sections/Navbar";
import { locations } from "../../data/locations";
import { FooterSection } from "../../sections/FooterSection";
---

<Layout
  title="Our Service Areas | Exterior Cleaning Near You | Jimbos Cleaning"
  description="Exterior cleaning across Ayrshire and Glasgow. We come to you in Irvine, Kilmarnock, Ayr, Troon, Prestwick and more. Roof, driveway, gutter and window cleaning. Get a free quote."
  canonical="https://jimboscleaning.com/locations"
>
  <div class="min-h-screen bg-neutral-100 font-figtree text-black text-sm leading-5 antialiased">
    <Navbar client:load />
    <main class="pt-0">
      <section class="bg-white py-16 md:py-24">
        <div class="max-w-[1204px] mx-auto px-5 md:px-8">
          <h1 class="text-3xl font-bold tracking-tight md:text-5xl font-heading uppercase mb-4">
            Our service areas
          </h1>
          <p class="text-blue-700 text-base md:text-lg max-w-[640px] mb-12">
            We provide mobile exterior cleaning across Ayrshire and Glasgow. Select your area to see our services and book.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {locations.map((loc) => (
              <a
                href={`/${loc.slug}`}
                class="block p-6 rounded-lg border border-neutral-200 bg-white hover:border-cta hover:shadow-md transition-all"
              >
                <h2 class="text-xl font-bold font-heading uppercase text-black mb-2">
                  {loc.name}
                </h2>
                <p class="text-[15px] text-blue-600 leading-6">
                  Exterior cleaning in {loc.name}
                  {loc.neighborhoods?.length ? ` and nearby areas` : ""}. Book online or get in touch.
                </p>
                <span class="inline-block mt-3 text-sm font-medium text-cta-dark">
                  View services →
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
      <FooterSection client:load />
    </main>
  </div>
</Layout>
