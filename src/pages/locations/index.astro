---
import Layout from "../../layouts/Layout.astro";
import { Navbar } from "../../sections/Navbar";
import {
  LOCATION_REGION_ORDER,
  locationsInRegion,
} from "../../data/locations";
import { FooterSection } from "../../sections/FooterSection";
import {
  BUSINESS_NAME,
  META_AREA_PHRASE,
} from "../../constants/site";
---

<Layout
  title={`Our Service Areas | Exterior Cleaning Near You | ${BUSINESS_NAME}`}
  description={`Exterior cleaning across ${META_AREA_PHRASE}. We cover Morningside, North Berwick, Linlithgow, Livingston and nearby towns. Roof, driveway, gutter and window cleaning. Get a free quote.`}
>
  <div class="min-h-screen bg-neutral-100 font-figtree text-black text-sm leading-5 antialiased">
    <Navbar client:load />
    <main class="pt-0">
      <section class="bg-white py-16 md:py-24">
        <div class="max-w-[1204px] mx-auto px-5 md:px-8">
          <h1 class="text-3xl font-bold tracking-tight md:text-5xl font-heading uppercase mb-4">
            Our service areas
          </h1>
          <p class="text-neutral-700 text-base md:text-lg max-w-[640px] mb-12">
            We provide mobile exterior cleaning across {META_AREA_PHRASE}. Select your area to see our services and book.
          </p>
          {LOCATION_REGION_ORDER.map((region) => {
            const regionLocs = locationsInRegion(region.id);
            return (
              <div class="mb-14 last:mb-0">
                <h2 class="text-xl md:text-2xl font-heading uppercase font-bold text-black mb-6 border-b border-neutral-200 pb-2">
                  {region.title}
                </h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                  {regionLocs.map((loc) => (
                    <a
                      href={`/${loc.slug}/`}
                      class="block p-6 rounded-lg border border-neutral-200 bg-white hover:border-cta hover:shadow-md transition-all"
                    >
                      <h3 class="text-xl font-bold font-heading uppercase text-black mb-2">
                        {loc.name}
                      </h3>
                      <p class="text-[15px] text-neutral-600 leading-6">
                        Exterior cleaning in {loc.name}
                        {loc.neighborhoods?.length ? ` and nearby areas` : ""}. Book online or get in touch.
                      </p>
                      <span class="inline-block mt-3 text-sm font-medium text-neutral-800">
                        View services →
                      </span>
                    </a>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      </section>
      <FooterSection client:load />
    </main>
  </div>
</Layout>
