---
import '../styles/tailwind.css';
import { locations } from '../data/locations';
import {
  SITE_URL,
  BUSINESS_NAME,
  PHONE_E164,
  REGISTERED_STREET,
  REGISTERED_LOCALITY,
  REGISTERED_REGION,
  REGISTERED_POSTCODE,
  REGISTERED_GEO,
  META_AREA_PHRASE,
  FACEBOOK_PROFILE_URL,
} from '../constants/site';

interface LocationSchemaProp {
  name: string;
  slug: string;
  addressLocality: string;
  latitude: string;
  longitude: string;
}

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  canonical?: string;
  noindex?: boolean;
  locationSchema?: LocationSchemaProp;
}

const siteUrl = SITE_URL;
// Canonical: trailing slash (trailingSlash: 'always' in astro.config).
const pathname = Astro.url.pathname;
const pathWithSlash = pathname.endsWith("/") ? pathname : pathname + "/";
const defaultCanonical =
  pathWithSlash === "/" ? `${siteUrl}/` : `${siteUrl}${pathWithSlash}`;

const {
  title = `${BUSINESS_NAME} - Professional Exterior Cleaning | ${META_AREA_PHRASE}`,
  description = `Expert roof cleaning, render softwashing, driveway, gutter, PVC and window cleaning across ${META_AREA_PHRASE}. Professional exterior cleaning for your home or business.`,
  image = `${SITE_URL}/og-default.png`,
  type = "website",
  canonical = defaultCanonical,
  noindex = false,
  locationSchema,
} = Astro.props;

const fullImageUrl = image.startsWith('http') ? image : `${siteUrl}${image}`;

const defaultAreaServed = [
  ...locations.map((loc) => ({ "@type": "City", "name": loc.name })),
  { "@type": "AdministrativeArea", "name": "Edinburgh" },
  { "@type": "AdministrativeArea", "name": "Midlothian" },
  { "@type": "AdministrativeArea", "name": "East Lothian" },
  { "@type": "AdministrativeArea", "name": "West Lothian" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="any" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={BUSINESS_NAME} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <meta name="language" content="English" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonical} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={BUSINESS_NAME} />
    <meta property="og:locale" content="en_GB" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImageUrl} />
    
    <!-- Business Information -->
    <meta name="geo.region" content="GB-SCT" />
    <meta name="geo.placename" content={`${REGISTERED_LOCALITY}, ${REGISTERED_REGION}, Scotland`} />
    <meta name="geo.position" content={`${REGISTERED_GEO.latitude};${REGISTERED_GEO.longitude}`} />
    <meta name="ICBM" content={`${REGISTERED_GEO.latitude}, ${REGISTERED_GEO.longitude}`} />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-YMJS781CJF"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-YMJS781CJF');
    </script>
    
    <!-- JSON-LD Schema: LocalBusiness (primary) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["LocalBusiness", "HomeAndConstructionBusiness"],
      "@id": `${siteUrl}/#localbusiness`,
      "name": BUSINESS_NAME,
      "description": `Expert roof cleaning and exterior cleaning across ${META_AREA_PHRASE}. Roof steam cleaning, render softwashing, driveway, gutter, PVC and window cleaning.`,
      "url": siteUrl,
      "logo": `${siteUrl}/logo.png`,
      "image": [`${siteUrl}/logo.png`, `${siteUrl}/og-default.png`],
      "telephone": PHONE_E164,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": REGISTERED_STREET,
        "addressLocality": REGISTERED_LOCALITY,
        "addressRegion": REGISTERED_REGION,
        "postalCode": REGISTERED_POSTCODE,
        "addressCountry": "GB"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": REGISTERED_GEO.latitude,
        "longitude": REGISTERED_GEO.longitude
      },
      "areaServed": defaultAreaServed,
      "serviceType": [
        "Roof Cleaning",
        "Roof Steam Cleaning",
        "Render Softwashing",
        "Driveway Cleaning",
        "Gutter Cleaning",
        "PVC Cleaning",
        "Window Cleaning",
        "Exterior Cleaning"
      ],
      "priceRange": "££",
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "08:00",
        "closes": "18:00"
      },
      "sameAs": [
        FACEBOOK_PROFILE_URL
      ],
      "parentOrganization": { "@id": `${siteUrl}/#organization` }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "name": BUSINESS_NAME,
      "url": siteUrl,
      "description": `Professional exterior cleaning across ${META_AREA_PHRASE}. Roof steam cleaning, render softwashing, driveway, gutter, PVC and window cleaning.`,
      "publisher": { "@id": `${siteUrl}/#organization` },
      "inLanguage": "en-GB"
    })} />
    
    {locationSchema && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": `${BUSINESS_NAME} – ${locationSchema.name}`,
        "description": "Professional exterior cleaning: roof steam cleaning, render softwashing, driveway, gutter, PVC and window cleaning.",
        "url": `${siteUrl}/${locationSchema.slug}/`,
        "telephone": PHONE_E164,
        "address": {
          "@type": "PostalAddress",
          "addressLocality": locationSchema.addressLocality,
          "addressRegion": "Scotland",
          "addressCountry": "GB"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": locationSchema.latitude,
          "longitude": locationSchema.longitude
        },
        "areaServed": { "@type": "City", "name": locationSchema.addressLocality },
        "serviceType": ["Roof Cleaning", "Render Softwashing", "Driveway Cleaning", "Gutter Cleaning", "PVC Cleaning", "Window Cleaning", "Exterior Cleaning"],
        "priceRange": "££"
      })} />
    )}
    
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      "name": BUSINESS_NAME,
      "url": siteUrl,
      "logo": `${siteUrl}/logo.png`,
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": PHONE_E164,
        "contactType": "Customer Service",
        "areaServed": "GB",
        "availableLanguage": "English"
      },
      "sameAs": [
        FACEBOOK_PROFILE_URL
      ]
    })} />
  </head>
  <body>
    <slot />
    <!-- Mobile message widget - bottom right, visible on small screens only -->
    <a
      href="/contact/"
      class="fixed bottom-5 right-5 z-50 flex md:hidden items-center gap-2 bg-cta-dark text-white px-4 py-3 rounded-full shadow-lg hover:bg-cta focus:outline-none focus:ring-2 focus:ring-cta-dark focus:ring-offset-2"
      aria-label="Message us / Get a quote"
    >
      <svg class="w-6 h-6 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.864 9.864 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
      </svg>
      <span class="font-medium text-sm">Message</span>
    </a>
  </body>
</html>
